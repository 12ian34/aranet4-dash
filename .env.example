ARANET_MAC=XX:XX:XX:XX:XX:XX
DB_PATH=/var/lib/aranet4-dash/aranet.db
POLL_INTERVAL=60
# Optional: only set after `busctl tree org.bluez` — must match a real adapter path.
# Wrong value (e.g. hci1 when the Pi only has hci0) breaks StopDiscovery / InProgress fix.
# BLUEZ_ADAPTER_DBUS_PATH=/org/bluez/hci0
