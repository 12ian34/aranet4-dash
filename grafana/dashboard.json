    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 6,
      "title": "CO2 over time",
      "type": "timeseries",
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "queryType": "time series",
          "rawQueryText": "SELECT timestamp AS time, co2_ppm FROM aranet_readings WHERE timestamp >= datetime('now', '-24 hours') ORDER BY timestamp",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ppm",
          "min": 400,
          "max": 2000,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": false,
            "lineWidth": 2,
            "thresholdsStyle": {
              "mode": "dashed+area"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 800 },
              { "color": "red", "value": 1000 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
