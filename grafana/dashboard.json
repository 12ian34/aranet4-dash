  "panels": [
    {
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 0 },
      "id": 1,
      "title": "CO2",
      "type": "stat",
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "targets": [
        {
          "rawQueryText": "SELECT co2_ppm FROM aranet_readings ORDER BY timestamp DESC LIMIT 1",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ppm",
          "min": 400,
          "max": 2000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 800 },
              { "color": "red", "value": 1000 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
